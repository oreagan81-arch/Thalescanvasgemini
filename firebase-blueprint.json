{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile allowed to use the system",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin"] },
        "createdAt": { "type": "number" },
        "lastLogin": { "type": "number" }
      },
      "required": ["email", "role"]
    },
    "Week": {
      "title": "Week metadata",
      "description": "Metadata for a specific week",
      "type": "object",
      "properties": {
        "weekId": { "type": "string" },
        "startDate": { "type": "number" },
        "endDate": { "type": "number" },
        "label": { "type": "string" },
        "isDeployed": { "type": "boolean" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["weekId", "startDate", "endDate", "isDeployed"]
    },
    "PlannerRow": {
      "title": "Planner Row",
      "description": "A specific lesson plan block",
      "type": "object",
      "properties": {
        "weekId": { "type": "string" },
        "day": { "type": "string", "enum": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"] },
        "subject": { "type": "string" },
        "lessonNum": { "type": "string" },
        "lessonTitle": { "type": "string" },
        "type": { "type": "string", "enum": ["Lesson", "Test", "Quiz", "Project", "Review"] },
        "resources": { "type": "array", "items": { "type": "string" } },
        "homework": { "type": "string" },
        "reminder": { "type": "string" },
        "notes": { "type": "string" },
        "deployStatus": { "type": "string", "enum": ["Draft", "Ready", "Deployed", "Failed"] },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["weekId", "day", "subject", "deployStatus"]
    },
    "ResourceFile": {
      "title": "Resource File",
      "description": "Information mapped from Canvas files",
      "type": "object",
      "properties": {
        "fileId": { "type": "string" },
        "rawName": { "type": "string" },
        "cleanName": { "type": "string" },
        "subject": { "type": "string" },
        "type": { "type": "string" },
        "canvasUrl": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["fileId", "rawName", "cleanName", "canvasUrl"]
    },
    "Announcement": {
      "title": "Announcement",
      "description": "Parent-facing announcement text",
      "type": "object",
      "properties": {
        "weekId": { "type": "string" },
        "content": { "type": "string" },
        "status": { "type": "string", "enum": ["Draft", "Posted"] },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["weekId", "content", "status"]
    },
    "Deployment": {
      "title": "Deployment Log",
      "description": "History of system deployments",
      "type": "object",
      "properties": {
        "weekId": { "type": "string" },
        "status": { "type": "string", "enum": ["Success", "Pending", "Failed"] },
        "logs": { "type": "array", "items": { "type": "string" } },
        "timestamp": { "type": "number" }
      },
      "required": ["weekId", "status", "timestamp"]
    },
    "Setting": {
      "title": "Setting",
      "description": "User specific configurations",
      "type": "object",
      "properties": {
        "teacherName": { "type": "string" },
        "schoolName": { "type": "string" },
        "signature": { "type": "string" },
        "tone": { "type": "string" },
        "canvasDomain": { "type": "string" },
        "canvasToken": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "CanvasPage": {
      "title": "Canvas Page",
      "description": "Staged HTML content for Canvas",
      "type": "object",
      "properties": {
        "weekId": { "type": "string" },
        "htmlContent": { "type": "string" },
        "status": { "type": "string", "enum": ["Draft", "Deployed"] },
        "canvasPageId": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["weekId", "htmlContent", "status"]
    },
    "Assignment": {
      "title": "Assignment",
      "description": "Canvas LMS assignments",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "weekId": { "type": "string" },
        "rowId": { "type": "string" },
        "subject": { "type": "string" },
        "title": { "type": "string" },
        "courseId": { "type": "number" },
        "type": { "type": "string", "enum": ["Assignment", "Quiz", "Discussion"] },
        "dueDate": { "type": "object" },
        "status": { "type": "string", "enum": ["Pending", "Drafted", "Deployed"] },
        "canvasId": { "type": "string" },
        "isGraded": { "type": "boolean" },
        "confidence": { "type": "number" },
        "createdAt": { "type": "object" },
        "testNumber": { "type": "number" },
        "powerUp": { "type": "string" },
        "factSkill": { "type": "string" },
        "isTimed": { "type": "boolean" },
        "hasStudyGuide": { "type": "boolean" }
      },
      "required": ["userId", "weekId", "rowId", "subject", "title", "courseId", "type", "status"]
    }
  },
  "firestore": {
    "users": { "schema": "User", "description": "System users." },
    "weeks": { "schema": "Week", "description": "Weekly academic nodes." },
    "planner_rows": { "schema": "PlannerRow", "description": "Curriculum nodes." },
    "resources": { "schema": "ResourceFile", "description": "LMS file registry." },
    "announcements": { "schema": "Announcement", "description": "Parent communication drafts." },
    "deployments": { "schema": "Deployment", "description": "Audit trail." },
    "settings": { "schema": "Setting", "description": "User preference profile." },
    "canvas_pages": { "schema": "CanvasPage", "description": "HTML staging area." },
    "assignments": { "schema": "Assignment", "description": "LMS assignment registry." },
    "artifacts/{appId}/users/{userId}/planner_rows": { "schema": "PlannerRow", "description": "Artifact-scoped user planner rows." },
    "artifacts/{appId}/users/{userId}/announcements": { "schema": "Announcement", "description": "Artifact-scoped user announcements." },
    "artifacts/{appId}/users/{userId}/settings": { "schema": "Setting", "description": "Artifact-scoped user settings." },
    "artifacts/{appId}/public/data": { "schema": "object", "description": "Shared artifact data." }
  }
}
